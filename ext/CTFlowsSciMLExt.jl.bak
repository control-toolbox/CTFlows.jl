module CTFlowsSciMLExt

using CTFlows
using CTFlows.Integrators: SciMLIntegrator, SciMLTag
using CTFlows.Core: AbstractTag
using CTBase.Exceptions: ExtensionError
using CTSolvers: CTSolvers
using CTSolvers.Strategies: Strategies
using SciMLBase: SciMLBase
using OrdinaryDiffEq: OrdinaryDiffEq, Tsit5

# ==============================================================================
# Override build_sciml_integrator with actual implementation
# ==============================================================================

"""
$(TYPEDSIGNATURES)

Build a `SciMLIntegrator` with the given options.

This implementation uses the CTSolvers strategy system to validate and bundle
options, then constructs a `SciMLIntegrator` with those options.

# Arguments
- `::Type{SciMLTag`: Tag type for dispatch.
- `mode::Symbol`: Strategy mode (`:strict` or `:relaxed`).
- `kwargs...`: Integrator options (e.g., `reltol`, `abstol`, `algorithm`).

# Returns
- `SciMLIntegrator`: The configured integrator.

# Example
\`\`\`julia-repl
julia> using CTFlows, OrdinaryDiffEqTsit5

julia> integrator = CTFlows.Integrators.SciMLIntegrator(reltol=1e-8, abstol=1e-10)
SciMLIntegrator(...)

julia> flow = CTFlows.Flow(vf, :sciml; reltol=1e-8)
Flow(...)
\`\`\`

See also: [`SciMLIntegrator`](@ref), [`CTFlows.Integrators.SciMLIntegrator`](@ref).
"""
function CTFlows.Integrators.build_sciml_integrator(::Type{SciMLTag}; mode::Symbol = :strict, kwargs...)
    # Define option definitions for SciML integrator
    option_definitions = [
        Strategies.OptionDefinition(
            name = :reltol,
            type = Float64,
            default = 1e-6,
            description = "Relative tolerance for ODE solver",
        ),
        Strategies.OptionDefinition(
            name = :abstol,
            type = Float64,
            default = 1e-8,
            description = "Absolute tolerance for ODE solver",
        ),
        Strategies.OptionDefinition(
            name = :algorithm,
            type = Symbol,
            default = :Tsit5,
            description = "SciML algorithm to use (e.g., :Tsit5, :Rodas4)",
        ),
    ]

    # Build strategy options
    options = Strategies.build_options(option_definitions; mode = mode, kwargs...)

    return SciMLIntegrator(options)
end

# ==============================================================================
# Override callable for SciMLIntegrator
# ==============================================================================

"""
$(TYPEDSIGNATURES)

Call a `SciMLIntegrator` to solve an ODE problem.

This implementation extracts the ODEProblem from the system, configures the
SciML solver with the integrator's options, and returns the solution.

# Arguments
- `integ::SciMLIntegrator`: The SciML integrator.
- `prob`: The ODEProblem to solve (from `Systems.ode_problem`).

# Returns
- The SciML ODE solution.

See also: [`SciMLIntegrator`](@ref), [`Systems.ode_problem`](@ref).
"""
function (integ::SciMLIntegrator)(prob)
    # Extract options
    reltol = Strategies.get_option(integ.options, :reltol)
    abstol = Strategies.get_option(integ.options, :abstol)
    algorithm_sym = Strategies.get_option(integ.options, :algorithm)

    # Map algorithm symbol to SciML algorithm
    algorithm = if algorithm_sym === :Tsit5
        Tsit5()
    else
        # For other algorithms, user would need to load appropriate package
        # This is a simplified version; could be extended
        Tsit5()
    end

    # Solve the ODE problem
    sol = SciMLBase.solve(prob, algorithm; reltol = reltol, abstol = abstol)

    return sol
end

end # module CTFlowsSciMLExt
